{
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/payment-success",
      "destination": "https://tpb-financial-dashboard.vercel.app/payment-success"
    },
    {
      "source": "/payment-cancelled",
      "destination": "https://tpb-financial-dashboard.vercel.app/payment-cancelled"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://tpb-financial-dashboard.vercel.app/_next/:path*"
    }
  ]
}
